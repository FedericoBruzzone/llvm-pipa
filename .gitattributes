* text=auto eol=lf whitespace=tab-in-indent,trailing-space,tabwidth=4

# Jupyter notebooks are generated by users, but they contain a lot of metadata that is not relevant to the code, so we mark them as generated to prevent them from being treated as source files.
*.ipynb linguist-generated=true

# Older git versions try to fix line endings on images and fonts, this prevents it.
*.png binary
*.ico binary
*.woff binary
*.woff2 binary

